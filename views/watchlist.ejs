   <!-- include the header -->
<%- include('include/_header') %>
<!-- /include header-->

<!-- Main Site -->
<main>
  <h1> Watchlist</h1>
  <div class="indexTopBar">
    <h1>K/C Drama Watchlist </h1>
    <% if (entries.length >0) { %>
      for <% entry in entries %>
      <div class="entry">
        <p><%= entry%>
        <button>Edit</button>
        <button>Move to Viewed</button>
        </p>
    <% } else { %>
      <p>No dramas added yet!</p>
    <% }

      %>
    <button id="addDramaBtn">Add Drama</button>
  </div>
</main>

<!-- Modal for adding a drama -->
<div id="addDramaModal" class="modal" style="display:none;">
  <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <h2 id="modalTitle">Add a Drama</h2>
    <form id="addDramaForm">
      <label>
        Drama name (required)
        <input type="text" name="dramaName" id="dramaName" required />
      </label>
      <label>
        Comments
        <textarea name="comments" id="comments"></textarea>
      </label>
      <label>
        Where to watch (optional)
        <input type="text" name="whereToWatch" id="whereToWatch" />
      </label>
      <div class="modal-actions">
        <button type="submit" id="modalSubmit">Submit</button>
        <button type="button" id="modalCancel">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/watchlist.js"></script>

<!-- include footer -->
<%- include('include/_footer') %>
<!-- /include footer -->